server {
    listen 8080;
    server_name _;

    root /home/site/wwwroot;
    index index.php;

    client_max_body_size 100M;

    # ‚îÄ‚îÄ Security: block access to sensitive paths ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

    # Block .htaccess and other dot-files
    location ~ /\. {
        deny all;
        return 404;
    }

    # Block access to PHP error/session logs
    location ~ ^/logs(/|$) {
        deny all;
        return 404;
    }

    # Block access to uploaded file attachments (served via API only)
    location ~ ^/tmp_attach(/|$) {
        deny all;
        return 404;
    }

    # Block the Nginx config file itself
    location = /default {
        deny all;
        return 404;
    }

    # ‚îÄ‚îÄ Slim sub-application routing ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

    # Apache mod_dir auto-appends trailing slashes; Nginx does not.
    # Exact-match locations have highest priority (above ^~ prefix locations).
    location = /session { return 301 https://$host$request_uri/; }
    location = /api { return 301 https://$host$request_uri/; }
    location = /v2 { return 301 https://$host$request_uri/; }
    location = /admin { return 301 https://$host$request_uri/; }
    location = /finance { return 301 https://$host$request_uri/; }
    location = /kiosk { return 301 https://$host$request_uri/; }
    location = /plugins { return 301 https://$host$request_uri/; }
    location = /external { return 301 https://$host$request_uri/; }
    location = /setup { return 301 https://$host$request_uri/; }
    location = /people { return 301 https://$host$request_uri/; }
    location = /groups { return 301 https://$host$request_uri/; }

    location ^~ /session {
        try_files $uri /session/index.php$is_args$args;

        location ~ \.php$ {
            fastcgi_pass   127.0.0.1:9000;
            fastcgi_index  index.php;
            include        fastcgi_params;
            fastcgi_param  SCRIPT_FILENAME $document_root$fastcgi_script_name;
            fastcgi_param  HTTPS on;
            fastcgi_param  SERVER_PORT 443;
            fastcgi_param  HTTP_HOST $host;
            fastcgi_param  HTTP_X_FORWARDED_PROTO https;
            fastcgi_param  REQUEST_URI $request_uri;
        }
    }

    location ^~ /api {
        try_files $uri /api/index.php$is_args$args;

        location ~ \.php$ {
            fastcgi_pass   127.0.0.1:9000;
